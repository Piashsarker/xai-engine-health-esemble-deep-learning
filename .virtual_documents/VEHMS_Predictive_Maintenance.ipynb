# ============================================================
# DynamicClassifierSelector Component
# ============================================================
# Purpose: Automatically select optimal classifier combinations
# for stacking based on diversity and performance metrics
# ============================================================

class DynamicClassifierSelector:
    """
    DynamicClassifierSelector class for automatically selecting optimal
    classifier combinations for stacked ensemble models.
    
    This class implements several research-based techniques:
    - Diversity-based selection using Q-statistic and disagreement measures
    - Performance-based selection using cross-validation accuracy
    - Greedy forward selection for iterative ensemble building
    - Combined approach using both diversity and performance
    
    Attributes:
        classifiers (dict): Dictionary of available classifiers
        cv (int): Number of cross-validation folds
        random_state (int): Random seed for reproducibility
    """
    
    def __init__(self, cv: int = 5, random_state: int = 42):
        """
        Initialize the DynamicClassifierSelector.
        
        Args:
            cv (int): Number of cross-validation folds (default: 5)
            random_state (int): Random seed for reproducibility (default: 42)
        """
        self.cv = cv
        self.random_state = random_state
        
        # Initialize all available classifiers
        self.classifiers = {
            'LR': LogisticRegression(max_iter=1000, random_state=random_state),
            'KNN': KNeighborsClassifier(n_neighbors=5),
            'LDA': LinearDiscriminantAnalysis(),
            'GNB': GaussianNB(),
            'SVM': SVC(kernel='rbf', probability=True, random_state=random_state),
            'DT': DecisionTreeClassifier(random_state=random_state),
            'RF': RandomForestClassifier(n_estimators=100, random_state=random_state),
            'AdaBoost': AdaBoostClassifier(n_estimators=100, random_state=random_state),
            'GB': GradientBoostingClassifier(n_estimators=100, random_state=random_state),
            'XGBoost': XGBClassifier(n_estimators=100, random_state=random_state,
                                      eval_metric='mlogloss')
        }
        
        self.predictions = {}
        self.accuracies = {}
        self.diversity_matrix = None
    
    def fit_all_classifiers(self, X_train, y_train, X_val=None, y_val=None):
        """Fit all classifiers and store their predictions."""
        from sklearn.base import clone
        if X_val is None:
            X_val, y_val = X_train, y_train
        print("[...] Fitting all classifiers...")
        for name, clf in self.classifiers.items():
            clf_clone = clone(clf)
            clf_clone.fit(X_train, y_train)
            self.predictions[name] = clf_clone.predict(X_val)
            self.accuracies[name] = accuracy_score(y_val, self.predictions[name])
            print(f"   {name}: {self.accuracies[name]:.4f}")
        return self.accuracies
    
    def calculate_q_statistic(self, pred1, pred2, y_true):
        """Calculate Q-statistic between two classifiers."""
        c1, c2 = (pred1 == y_true), (pred2 == y_true)
        n11, n00 = np.sum(c1 & c2), np.sum(~c1 & ~c2)
        n10, n01 = np.sum(c1 & ~c2), np.sum(~c1 & c2)
        denom = n11 * n00 + n01 * n10
        return (n11 * n00 - n01 * n10) / denom if denom != 0 else 0.0
    
    def calculate_diversity_matrix(self, y_true):
        """Calculate pairwise diversity matrix."""
        names = list(self.predictions.keys())
        n = len(names)
        matrix = np.zeros((n, n))
        for i, n1 in enumerate(names):
            for j, n2 in enumerate(names):
                matrix[i, j] = 1.0 if i == j else self.calculate_q_statistic(
                    self.predictions[n1], self.predictions[n2], y_true)
        self.diversity_matrix = pd.DataFrame(matrix, index=names, columns=names)
        return self.diversity_matrix
    
    def select_by_performance(self, top_k=5):
        """Select top-k classifiers by accuracy."""
        return [n for n, _ in sorted(self.accuracies.items(), key=lambda x: x[1], reverse=True)[:top_k]]
    
    def select_by_diversity(self, y_true, top_k=5):
        """Select classifiers maximizing diversity."""
        if self.diversity_matrix is None:
            self.calculate_diversity_matrix(y_true)
        names = list(self.predictions.keys())
        selected = [max(self.accuracies.items(), key=lambda x: x[1])[0]]
        while len(selected) < top_k and len(selected) < len(names):
            best = min([(n, np.mean([self.diversity_matrix.loc[n, s] for s in selected])) 
                        for n in names if n not in selected], key=lambda x: x[1], default=(None, 0))
            if best[0]: selected.append(best[0])
            else: break
        return selected
    
    def select_combined(self, y_true, top_k=5, perf_weight=0.6):
        """Select using combined performance and diversity."""
        if self.diversity_matrix is None:
            self.calculate_diversity_matrix(y_true)
        names = list(self.predictions.keys())
        selected = [max(self.accuracies.items(), key=lambda x: x[1])[0]]
        while len(selected) < top_k and len(selected) < len(names):
            scores = [(n, perf_weight * self.accuracies[n] + (1 - perf_weight) * 
                      (1 - np.mean([self.diversity_matrix.loc[n, s] for s in selected])))
                     for n in names if n not in selected]
            best = max(scores, key=lambda x: x[1], default=(None, 0))
            if best[0]: selected.append(best[0])
            else: break
        return selected
    
    def create_dynamic_stack(self, selected):
        """Create StackingClassifier from selected classifiers."""
        from sklearn.base import clone
        estimators = [(n.lower(), clone(self.classifiers[n])) for n in selected]
        return StackingClassifier(estimators=estimators,
            final_estimator=LogisticRegression(max_iter=1000, random_state=self.random_state),
            cv=self.cv, n_jobs=-1)
    
    def plot_diversity_heatmap(self):
        """Plot diversity heatmap."""
        if self.diversity_matrix is None:
            print("[!] Calculate diversity matrix first")
            return
        plt.figure(figsize=(12, 10))
        sns.heatmap(self.diversity_matrix, annot=True, fmt='.3f', 
                    cmap='RdYlGn_r', center=0, vmin=-1, vmax=1, square=True)
        plt.title('Classifier Diversity Matrix (Q-Statistic)', fontweight='bold')
        plt.tight_layout()
        plt.show()
    
    def display_selection_summary(self, method, selected):
        """Display selection summary."""
        print("\n" + "="*60)
        print(f"DYNAMIC CLASSIFIER SELECTION: {method.upper()}")
        print("="*60)
        for i, n in enumerate(selected, 1):
            acc = self.accuracies.get(n, 'N/A')
            print(f"   {i}. {n} (Acc: {acc:.4f})" if isinstance(acc, float) else f"   {i}. {n}")
        print("-"*60)

print("DynamicClassifierSelector class defined successfully!")





