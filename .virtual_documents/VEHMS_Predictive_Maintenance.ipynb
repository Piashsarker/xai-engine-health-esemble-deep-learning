# Add LIME methods to XAIExplainer class
def initialize_lime(self, X_train: np.ndarray, mode: str = 'classification') -> None:
    """
    Initialize LIME explainer for tabular data.
    
    Args:
        X_train (np.ndarray): Training data for LIME
        mode (str): 'classification' or 'regression'
    """
    print("\n[...] Initializing LIME explainer...")
    
    self.lime_explainer = lime.lime_tabular.LimeTabularExplainer(
        training_data=X_train,
        feature_names=self.feature_names,
        class_names=self.class_names,
        mode=mode,
        random_state=RANDOM_SEED
    )
    
    print(f"   [OK] LIME TabularExplainer initialized")
    print(f"   Features: {len(self.feature_names)}")
    print(f"   Classes: {self.class_names}")

def explain_instance_lime(self, instance: np.ndarray, num_features: int = 9) -> object:
    """
    Generate LIME explanation for a single instance.
    
    Args:
        instance (np.ndarray): Single sample to explain
        num_features (int): Number of features to include in explanation
        
    Returns:
        lime.explanation.Explanation: LIME explanation object
    """
    if self.lime_explainer is None:
        raise ValueError("LIME explainer not initialized. Call initialize_lime() first.")
    
    explanation = self.lime_explainer.explain_instance(
        instance,
        self.model.predict_proba,
        num_features=num_features,
        top_labels=len(self.class_names)
    )
    
    return explanation

def plot_lime_explanation(self, instance: np.ndarray, sample_idx: int = 0) -> None:
    """
    Generate LIME explanation visualization for a single instance.
    
    Args:
        instance (np.ndarray): Single sample to explain
        sample_idx (int): Sample index for display purposes
    """
    print("\n" + "="*60)
    print(f"LIME EXPLANATION - Sample {sample_idx}")
    print("="*60)
    
    # Get explanation
    explanation = self.explain_instance_lime(instance)
    
    # Get predicted class
    pred_proba = self.model.predict_proba(instance.reshape(1, -1))[0]
    pred_class = np.argmax(pred_proba)
    
    print(f"\n   Predicted Class: {self.class_names[pred_class]}")
    print(f"   Confidence: {pred_proba[pred_class]*100:.2f}%")
    
    # Display prediction probabilities
    print("\n   Prediction Probabilities:")
    for i, class_name in enumerate(self.class_names):
        print(f"   * {class_name}: {pred_proba[i]*100:.2f}%")
    
    # Plot explanation for predicted class
    fig = explanation.as_pyplot_figure(label=pred_class)
    plt.title(f'LIME Explanation - {self.class_names[pred_class]}', fontsize=14, fontweight='bold')
    plt.tight_layout()
    plt.show()
    
    # Display feature weights
    print("\n   Feature Contributions:")
    print("-" * 50)
    exp_list = explanation.as_list(label=pred_class)
    for feature_rule, weight in sorted(exp_list, key=lambda x: abs(x[1]), reverse=True):
        direction = "^" if weight > 0 else "v"
        print(f"   {direction} {feature_rule}: {weight:+.4f}")
    
    print("\n[OK] LIME explanation generated")
    
    return explanation

def get_lime_feature_weights(self, explanation, class_idx: int = None) -> dict:
    """
    Extract feature weights from LIME explanation.
    
    Args:
        explanation: LIME explanation object
        class_idx (int, optional): Class index. If None, uses top predicted class.
        
    Returns:
        dict: Feature weights dictionary
    """
    if class_idx is None:
        class_idx = explanation.top_labels[0]
    
    exp_list = explanation.as_list(label=class_idx)
    weights = {}
    
    for feature_rule, weight in exp_list:
        # Extract feature name from rule
        for feat_name in self.feature_names:
            if feat_name in feature_rule:
                weights[feat_name] = weight
                break
    
    return weights

def get_lime_prediction_proba(self, explanation) -> dict:
    """
    Get prediction probabilities from LIME explanation.
    
    Args:
        explanation: LIME explanation object
        
    Returns:
        dict: Class probabilities
    """
    proba = {}
    for i, class_name in enumerate(self.class_names):
        proba[class_name] = explanation.predict_proba[i]
    return proba

# Bind methods to XAIExplainer class
XAIExplainer.initialize_lime = initialize_lime
XAIExplainer.explain_instance_lime = explain_instance_lime
XAIExplainer.plot_lime_explanation = plot_lime_explanation
XAIExplainer.get_lime_feature_weights = get_lime_feature_weights
XAIExplainer.get_lime_prediction_proba = get_lime_prediction_proba

print("[OK] LIME methods added to XAIExplainer class")


