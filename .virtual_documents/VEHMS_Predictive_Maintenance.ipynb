# ============================================================
# ExistingResearchStackedEnsemble Component
# ============================================================
# Purpose: Construct stacked ensemble models based on existing research
# for comparison with our proposed configurations
# ============================================================

class ExistingResearchStackedEnsemble:
    """
    ExistingResearchStackedEnsemble class for constructing stacked ensemble models
    based on configurations from existing research literature.
    
    This class provides methods to:
    - Create 3 different stacking configurations from existing research
    - Define LogisticRegression as the meta-learner for final predictions
    - Train stacked models using cross-validation to prevent data leakage
    - Display the architecture of each stacked model
    
    Existing Research Stacked Model Configurations:
    - ER-Stacked Model 1: RF + SVM + GB + DT + KNN (5 classifiers)
    - ER-Stacked Model 2: LR + SVM + LDA + GB + AdaBoost (5 classifiers)
    - ER-Stacked Model 3: LR + KNN + SVM + LDA + GB + AdaBoost + DT + RF + GNB (9 classifiers)
    
    Attributes:
        cv (int): Number of cross-validation folds (default: 5)
        random_state (int): Random seed for reproducibility
        stacked_models (dict): Dictionary storing trained stacked models
        training_times (dict): Dictionary storing training times for each model
    """
    
    def __init__(self, cv: int = 5, random_state: int = 42):
        """
        Initialize the ExistingResearchStackedEnsemble instance.
        
        Args:
            cv (int): Number of cross-validation folds (default: 5)
            random_state (int): Random seed for reproducibility (default: 42)
        """
        self.cv = cv
        self.random_state = random_state
        self.stacked_models = {}
        self.training_times = {}
    
    def create_er_stacked_model_1(self) -> StackingClassifier:
        """
        Create ER-Stacked Model 1: RF + SVM + GB + DT + KNN.
        
        This configuration combines tree-based and instance-based classifiers
        as described in existing research literature.
        
        Returns:
            StackingClassifier: Configured stacking classifier with 5 base estimators
        """
        estimators = [
            ('rf', RandomForestClassifier(n_estimators=100, random_state=self.random_state)),
            ('svm', SVC(kernel='rbf', probability=True, random_state=self.random_state)),
            ('gb', GradientBoostingClassifier(n_estimators=100, random_state=self.random_state)),
            ('dt', DecisionTreeClassifier(random_state=self.random_state)),
            ('knn', KNeighborsClassifier(n_neighbors=5))
        ]
        
        return StackingClassifier(
            estimators=estimators,
            final_estimator=LogisticRegression(max_iter=1000, random_state=self.random_state),
            cv=self.cv,
            n_jobs=-1
        )
    
    def create_er_stacked_model_2(self) -> StackingClassifier:
        """
        Create ER-Stacked Model 2: LR + SVM + LDA + GB + AdaBoost.
        
        This configuration combines linear models with boosting methods
        as described in existing research literature.
        
        Returns:
            StackingClassifier: Configured stacking classifier with 5 base estimators
        """
        estimators = [
            ('lr', LogisticRegression(max_iter=1000, random_state=self.random_state)),
            ('svm', SVC(kernel='rbf', probability=True, random_state=self.random_state)),
            ('lda', LinearDiscriminantAnalysis()),
            ('gb', GradientBoostingClassifier(n_estimators=100, random_state=self.random_state)),
            ('ada', AdaBoostClassifier(n_estimators=100, random_state=self.random_state))
        ]
        
        return StackingClassifier(
            estimators=estimators,
            final_estimator=LogisticRegression(max_iter=1000, random_state=self.random_state),
            cv=self.cv,
            n_jobs=-1
        )
    
    def create_er_stacked_model_3(self) -> StackingClassifier:
        """
        Create ER-Stacked Model 3: LR + KNN + SVM + LDA + GB + AdaBoost + DT + RF + GNB.
        
        This configuration uses all 9 base classifiers for comprehensive
        ensemble coverage as described in existing research literature.
        
        Returns:
            StackingClassifier: Configured stacking classifier with 9 base estimators
        """
        estimators = [
            ('lr', LogisticRegression(max_iter=1000, random_state=self.random_state)),
            ('knn', KNeighborsClassifier(n_neighbors=5)),
            ('svm', SVC(kernel='rbf', probability=True, random_state=self.random_state)),
            ('lda', LinearDiscriminantAnalysis()),
            ('gb', GradientBoostingClassifier(n_estimators=100, random_state=self.random_state)),
            ('ada', AdaBoostClassifier(n_estimators=100, random_state=self.random_state)),
            ('dt', DecisionTreeClassifier(random_state=self.random_state)),
            ('rf', RandomForestClassifier(n_estimators=100, random_state=self.random_state)),
            ('gnb', GaussianNB())
        ]
        
        return StackingClassifier(
            estimators=estimators,
            final_estimator=LogisticRegression(max_iter=1000, random_state=self.random_state),
            cv=self.cv,
            n_jobs=-1
        )
    
    def train_stacked_model(self, name: str, model: StackingClassifier, 
                            X_train: np.ndarray, y_train: np.ndarray) -> StackingClassifier:
        """
        Train a stacked ensemble model using cross-validation.
        
        Args:
            name (str): Name identifier for the stacked model
            model (StackingClassifier): Configured stacking classifier to train
            X_train (np.ndarray): Training feature array
            y_train (np.ndarray): Training target array
            
        Returns:
            StackingClassifier: Trained stacking classifier
        """
        import time
        
        print(f"\n[...] Training {name}...")
        print(f"   Base estimators: {[est[0] for est in model.estimators]}")
        print(f"   Meta-learner: LogisticRegression")
        print(f"   Cross-validation folds: {self.cv}")
        
        start_time = time.time()
        model.fit(X_train, y_train)
        training_time = time.time() - start_time
        
        # Store trained model and training time
        self.stacked_models[name] = model
        self.training_times[name] = training_time
        
        # Calculate training accuracy
        train_accuracy = model.score(X_train, y_train)
        
        print(f"\n[OK] {name} trained successfully!")
        print(f"   Training time: {training_time:.2f} seconds")
        print(f"   Training accuracy: {train_accuracy:.4f} ({train_accuracy*100:.2f}%)")
        
        return model
    
    def display_architecture(self, name: str) -> None:
        """
        Display the architecture of a stacked model as ASCII art.
        
        Args:
            name (str): Name of the stacked model to display
        """
        if name not in self.stacked_models:
            print(f"[!] Model '{name}' not found. Train the model first.")
            return
        
        model = self.stacked_models[name]
        estimator_names = [est[0].upper() for est in model.estimators]
        
        print("\n" + "="*70)
        print(f"ARCHITECTURE: {name}")
        print("="*70)
        
        # Input layer
        print("\n" + " "*20 + "+" + "-"*28 + "+")
        print(" "*20 + "|" + "    Input Features (9)     " + "|")
        print(" "*20 + "+" + "-"*28 + "+")
        print(" "*33 + "|")
        print(" "*33 + "v")
        
        # Base classifiers layer (Level 0)
        print("\n" + " "*5 + "+" + "-"*60 + "+")
        print(" "*5 + "|" + " "*15 + "Level 0: Base Classifiers" + " "*20 + "|")
        print(" "*5 + "|" + "-"*60 + "|")
        
        # Display base classifiers
        classifier_line = "|  "
        for est_name in estimator_names:
            classifier_line += f"[{est_name:^6}] "
        classifier_line = classifier_line.ljust(65) + "|"
        print(" "*5 + classifier_line)
        
        print(" "*5 + "+" + "-"*60 + "+")
        print(" "*33 + "|")
        print(" "*33 + "v")
        
        # Meta-learner layer (Level 1)
        print("\n" + " "*15 + "+" + "-"*38 + "+")
        print(" "*15 + "|" + "    Level 1: Meta-Learner            " + "|")
        print(" "*15 + "|" + "-"*38 + "|")
        print(" "*15 + "|" + "    Logistic Regression              " + "|")
        print(" "*15 + "+" + "-"*38 + "+")
        print(" "*33 + "|")
        print(" "*33 + "v")
        
        # Output layer
        print("\n" + " "*15 + "+" + "-"*38 + "+")
        print(" "*15 + "|" + "        Final Prediction             " + "|")
        print(" "*15 + "|" + " Good | Minor | Moderate | Critical " + "|")
        print(" "*15 + "+" + "-"*38 + "+")
        
        # Model details
        print("\n" + "-"*70)
        print(f"Model Details:")
        print(f"  - Base Classifiers: {', '.join(estimator_names)}")
        print(f"  - Number of Base Classifiers: {len(estimator_names)}")
        print(f"  - Meta-Learner: Logistic Regression (max_iter=1000)")
        print(f"  - Cross-Validation Folds: {self.cv}")
        print(f"  - Random State: {self.random_state}")
        if name in self.training_times:
            print(f"  - Training Time: {self.training_times[name]:.2f} seconds")
        print("-"*70)
    
    def get_model(self, name: str) -> StackingClassifier:
        """
        Retrieve a trained stacked model by name.
        
        Args:
            name (str): Name of the stacked model to retrieve
            
        Returns:
            StackingClassifier: The trained stacking classifier
        """
        if name not in self.stacked_models:
            raise KeyError(f"Model '{name}' not found. Available models: {list(self.stacked_models.keys())}")
        return self.stacked_models[name]
    
    def get_all_models(self) -> dict:
        """
        Retrieve all trained stacked models.
        
        Returns:
            dict: Dictionary of all trained stacking classifiers
        """
        return self.stacked_models


