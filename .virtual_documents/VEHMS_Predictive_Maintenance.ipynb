def compare_shap_lime(self, sample_idx: int = 0, class_idx: int = None) -> pd.DataFrame:
    """
    Compare SHAP and LIME feature importance rankings for a sample.
    
    Args:
        sample_idx (int): Index of sample to compare
        class_idx (int, optional): Class index for comparison
        
    Returns:
        pd.DataFrame: Comparison of SHAP vs LIME rankings
    """
    if self.shap_values is None:
        raise ValueError("SHAP values not calculated.")
    if self.lime_explainer is None:
        raise ValueError("LIME explainer not initialized.")
    
    # Get predicted class if not specified
    if class_idx is None:
        pred_proba = self.model.predict_proba(self.X_sample[sample_idx:sample_idx+1])
        class_idx = np.argmax(pred_proba)
    
    # Get SHAP values for this sample using helper method
    shap_class_vals = self._get_shap_values_for_class(class_idx)
    shap_vals = shap_class_vals[sample_idx]
    shap_importance = {feat: abs(val) for feat, val in zip(self.feature_names, shap_vals)}
    
    # Get LIME explanation
    lime_exp = self.explain_instance_lime(self.X_sample[sample_idx])
    lime_weights = self.get_lime_feature_weights(lime_exp, class_idx)
    lime_importance = {feat: abs(lime_weights.get(feat, 0)) for feat in self.feature_names}
    
    # Create comparison DataFrame
    comparison_data = []
    for feat in self.feature_names:
        comparison_data.append({
            'Feature': feat,
            'SHAP |Value|': shap_importance[feat],
            'LIME |Weight|': lime_importance[feat]
        })
    
    comparison_df = pd.DataFrame(comparison_data)
    
    # Add rankings
    comparison_df['SHAP Rank'] = comparison_df['SHAP |Value|'].rank(ascending=False).astype(int)
    comparison_df['LIME Rank'] = comparison_df['LIME |Weight|'].rank(ascending=False).astype(int)
    comparison_df['Rank Diff'] = abs(comparison_df['SHAP Rank'] - comparison_df['LIME Rank'])
    
    return comparison_df.sort_values('SHAP Rank')

def plot_comparison_visualization(self, sample_idx: int = 0, class_idx: int = None) -> None:
    """
    Generate side-by-side SHAP vs LIME comparison visualization.
    
    Args:
        sample_idx (int): Index of sample to compare
        class_idx (int, optional): Class index for comparison
    """
    print("\n" + "="*80)
    print(f"SHAP vs LIME COMPARISON - Sample {sample_idx}")
    print("="*80)
    
    # Get comparison data
    comparison_df = self.compare_shap_lime(sample_idx, class_idx)
    
    # Get predicted class
    if class_idx is None:
        pred_proba = self.model.predict_proba(self.X_sample[sample_idx:sample_idx+1])
        class_idx = np.argmax(pred_proba)
    
    print(f"\n   Predicted Class: {self.class_names[class_idx]}")
    
    # Create side-by-side bar chart
    fig, axes = plt.subplots(1, 2, figsize=(16, 8))
    
    # SHAP bar chart
    shap_sorted = comparison_df.sort_values('SHAP |Value|', ascending=True)
    axes[0].barh(shap_sorted['Feature'], shap_sorted['SHAP |Value|'], color='steelblue')
    axes[0].set_xlabel('|SHAP Value|', fontsize=12)
    axes[0].set_ylabel('Feature', fontsize=12)
    axes[0].set_title('SHAP Feature Importance', fontsize=14, fontweight='bold')
    
    # LIME bar chart
    lime_sorted = comparison_df.sort_values('LIME |Weight|', ascending=True)
    axes[1].barh(lime_sorted['Feature'], lime_sorted['LIME |Weight|'], color='coral')
    axes[1].set_xlabel('|LIME Weight|', fontsize=12)
    axes[1].set_ylabel('Feature', fontsize=12)
    axes[1].set_title('LIME Feature Importance', fontsize=14, fontweight='bold')
    
    plt.suptitle(f'SHAP vs LIME Comparison - {self.class_names[class_idx]}', 
                 fontsize=16, fontweight='bold', y=1.02)
    plt.tight_layout()
    plt.show()
    
    # Display comparison table
    print("\n   Feature Importance Ranking Comparison:")
    print("-" * 70)
    print(comparison_df.to_string(index=False))
    
    # Calculate rank correlation
    from scipy.stats import spearmanr
    corr, p_value = spearmanr(comparison_df['SHAP Rank'], comparison_df['LIME Rank'])
    print(f"\n   Spearman Rank Correlation: {corr:.4f} (p-value: {p_value:.4f})")
    
    print("\n[OK] Comparison visualization generated")

def analyze_class_influences(self) -> dict:
    """
    Identify features influencing each Engine_Health_Status category.
    
    Returns:
        dict: Top features for each class
    """
    if self.shap_values is None:
        raise ValueError("SHAP values not calculated.")
    
    print("\n" + "="*80)
    print("CLASS-SPECIFIC FEATURE INFLUENCE ANALYSIS")
    print("="*80)
    
    class_influences = {}
    
    for class_idx, class_name in enumerate(self.class_names):
        # Calculate mean absolute SHAP values for this class
        mean_shap = np.abs(self._get_shap_values_for_class(class_idx)).mean(axis=0)
        
        # Create ranking
        feature_importance = list(zip(self.feature_names, mean_shap))
        feature_importance.sort(key=lambda x: x[1], reverse=True)
        
        class_influences[class_name] = feature_importance
        
        print(f"\n   {class_name}:")
        print("   " + "-" * 40)
        for rank, (feat, importance) in enumerate(feature_importance[:5], 1):
            print(f"   {rank}. {feat:<15} {importance:.4f}")
    
    return class_influences

def generate_natural_language_explanation(self, sample_idx: int = 0) -> str:
    """
    Generate natural language explanation combining SHAP and LIME insights.
    
    Args:
        sample_idx (int): Index of sample to explain
        
    Returns:
        str: Natural language explanation
    """
    print("\n" + "="*80)
    print(f"NATURAL LANGUAGE EXPLANATION - Sample {sample_idx}")
    print("="*80)
    
    # Get prediction
    instance = self.X_sample[sample_idx]
    pred_proba = self.model.predict_proba(instance.reshape(1, -1))[0]
    pred_class = np.argmax(pred_proba)
    confidence = pred_proba[pred_class] * 100
    
    # Get SHAP values
    shap_vals = self._get_shap_values_for_class(pred_class)[sample_idx]
    shap_importance = list(zip(self.feature_names, shap_vals))
    shap_importance.sort(key=lambda x: abs(x[1]), reverse=True)
    
    # Get LIME explanation
    lime_exp = self.explain_instance_lime(instance)
    lime_weights = self.get_lime_feature_weights(lime_exp, pred_class)
    
    # Generate explanation
    explanation = f"\n   [NOTE] Prediction Explanation:\n"
    explanation += f"   " + "-" * 60 + "\n"
    explanation += f"   The model predicts this engine has '{self.class_names[pred_class]}' health status\n"
    explanation += f"   with {confidence:.1f}% confidence.\n\n"
    
    explanation += f"   Key factors influencing this prediction:\n"
    
    # Top 3 contributing features
    for i, (feat, shap_val) in enumerate(shap_importance[:3], 1):
        direction = "increases" if shap_val > 0 else "decreases"
        feature_value = instance[self.feature_names.index(feat)]
        explanation += f"   {i}. {feat} (value: {feature_value:.2f}) {direction} the likelihood\n"
        explanation += f"      of '{self.class_names[pred_class]}' status (SHAP: {shap_val:+.4f})\n"
    
    explanation += f"\n   Both SHAP and LIME agree that the top contributing features are:\n"
    
    # Find common top features
    shap_top = set([f[0] for f in shap_importance[:3]])
    lime_top = set(sorted(lime_weights.keys(), key=lambda x: abs(lime_weights[x]), reverse=True)[:3])
    common = shap_top.intersection(lime_top)
    
    for feat in common:
        explanation += f"   * {feat}\n"
    
    if not common:
        explanation += f"   (No common features in top 3 - methods show different perspectives)\n"
    
    print(explanation)
    
    return explanation

