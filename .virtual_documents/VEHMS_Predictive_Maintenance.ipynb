# ============================================================
# XAIExplainer Class - SHAP Methods
# ============================================================
# Purpose: Implement SHAP-based explainability methods
# Requirements: 12.1, 12.2, 12.3, 12.4, 12.5, 12.6
# ============================================================

class XAIExplainer:
    """
    XAIExplainer class for generating model explanations using SHAP and LIME.
    
    This class provides comprehensive explainability methods including:
    - SHAP TreeExplainer for ensemble models
    - SHAP summary, force, waterfall, and dependence plots
    - LIME tabular explanations for individual predictions
    - Combined analysis comparing SHAP and LIME insights
    
    Attributes:
        model: The trained model to explain
        feature_names (list): Names of input features
        class_names (list): Names of target classes
        shap_explainer: SHAP explainer instance
        lime_explainer: LIME explainer instance
        shap_values: Computed SHAP values
    """
    
    def __init__(self, model, feature_names: list, class_names: list):
        """
        Initialize the XAIExplainer instance.
        
        Args:
            model: Trained model to explain
            feature_names (list): Names of input features
            class_names (list): Names of target classes
        """
        self.model = model
        self.feature_names = feature_names
        self.class_names = class_names
        self.shap_explainer = None
        self.lime_explainer = None
        self.shap_values = None
        self.X_sample = None
    
    # ============================================================
    # SHAP Methods
    # ============================================================
    
    def initialize_shap(self, X_background: np.ndarray, max_samples: int = 100) -> None:
        """
        Initialize SHAP explainer using KernelExplainer for stacked models.
        
        Args:
            X_background (np.ndarray): Background data for SHAP
            max_samples (int): Maximum samples for background (default: 100)
        """
        print("\n[...] Initializing SHAP explainer...")
        
        # Use a subset of background data for efficiency
        if len(X_background) > max_samples:
            indices = np.random.choice(len(X_background), max_samples, replace=False)
            X_bg = X_background[indices]
        else:
            X_bg = X_background
        
        # Use KernelExplainer for model-agnostic explanations
        self.shap_explainer = shap.KernelExplainer(
            self.model.predict_proba, 
            X_bg
        )
        
        print(f"   [OK] SHAP KernelExplainer initialized")
        print(f"   Background samples: {len(X_bg)}")
    
    def calculate_shap_values(self, X: np.ndarray, max_samples: int = 200) -> np.ndarray:
        """
        Calculate SHAP values for given samples.
        
        Args:
            X (np.ndarray): Samples to explain
            max_samples (int): Maximum samples to explain (default: 200)
            
        Returns:
            np.ndarray: SHAP values for each sample
        """
        if self.shap_explainer is None:
            raise ValueError("SHAP explainer not initialized. Call initialize_shap() first.")
        
        print(f"\n[...] Calculating SHAP values for {min(len(X), max_samples)} samples...")
        
        # Limit samples for efficiency
        if len(X) > max_samples:
            indices = np.random.choice(len(X), max_samples, replace=False)
            X_sample = X[indices]
        else:
            X_sample = X
            indices = np.arange(len(X))
        
        self.X_sample = X_sample
        self.sample_indices = indices
        
        # Calculate SHAP values
        self.shap_values = self.shap_explainer.shap_values(X_sample)
        
        print(f"   [OK] SHAP values calculated")
        print(f"   Shape: {np.array(self.shap_values).shape}")
        
        return self.shap_values
    
    def _get_shap_values_for_class(self, class_idx: int) -> np.ndarray:
        """
        Get SHAP values for a specific class, handling different SHAP output formats.
        
        Args:
            class_idx (int): Class index
            
        Returns:
            np.ndarray: SHAP values for the specified class
        """
        # Handle different SHAP value formats
        if isinstance(self.shap_values, list):
            # Old format: list of arrays, one per class
            return self._get_shap_values_for_class(class_idx)
        elif hasattr(self.shap_values, 'values'):
            # New SHAP Explanation object format
            if len(self.shap_values.values.shape) == 3:
                # Shape: (n_samples, n_features, n_classes)
                return self.shap_values.values[:, :, class_idx]
            else:
                return self.shap_values.values
        elif isinstance(self.shap_values, np.ndarray):
            if len(self.shap_values.shape) == 3:
                # Shape: (n_classes, n_samples, n_features) or (n_samples, n_features, n_classes)
                if self.shap_values.shape[0] == len(self.class_names):
                    return self._get_shap_values_for_class(class_idx)
                else:
                    return self.shap_values[:, :, class_idx]
            else:
                return self.shap_values
        else:
            return self._get_shap_values_for_class(class_idx)
    
    def plot_shap_summary(self, class_idx: int = None) -> None:
        """
        Generate SHAP summary plot (beeswarm) showing feature importance.
        
        Args:
            class_idx (int, optional): Class index to plot. If None, plots for all classes.
        """
        if self.shap_values is None:
            raise ValueError("SHAP values not calculated. Call calculate_shap_values() first.")
        
        print("\n" + "="*60)
        print("SHAP SUMMARY PLOT")
        print("="*60)
        
        # Convert X_sample to DataFrame for better feature name handling
        X_df = pd.DataFrame(self.X_sample, columns=self.feature_names)
        
        if class_idx is not None:
            # Plot for specific class
            plt.figure(figsize=(12, 8))
            shap_vals = self._get_shap_values_for_class(class_idx)
            shap.summary_plot(
                shap_vals, 
                X_df,
                feature_names=self.feature_names,
                show=False
            )
            plt.title(f'SHAP Summary - {self.class_names[class_idx]}', fontsize=14, fontweight='bold')
            plt.tight_layout()
            plt.show()
        else:
            # Plot for all classes
            fig, axes = plt.subplots(2, 2, figsize=(16, 12))
            axes = axes.flatten()
            
            for idx, class_name in enumerate(self.class_names):
                plt.sca(axes[idx])
                shap_vals = self._get_shap_values_for_class(idx)
                shap.summary_plot(
                    shap_vals, 
                    X_df,
                    feature_names=self.feature_names,
                    show=False,
                    plot_size=None
                )
                axes[idx].set_title(f'{class_name}', fontsize=12, fontweight='bold')
            
            plt.suptitle('SHAP Summary Plots by Class', fontsize=16, fontweight='bold', y=1.02)
            plt.tight_layout()
            plt.show()
        
        print("\n[OK] SHAP summary plot generated")
    
    def plot_shap_bar(self, class_idx: int = 0) -> None:
        """
        Generate SHAP bar plot showing mean absolute SHAP values.
        
        Args:
            class_idx (int): Class index to plot (default: 0)
        """
        if self.shap_values is None:
            raise ValueError("SHAP values not calculated. Call calculate_shap_values() first.")
        
        print("\n" + "="*60)
        print("SHAP BAR PLOT - MEAN ABSOLUTE VALUES")
        print("="*60)
        
        # Calculate mean absolute SHAP values for each feature
        shap_vals = self._get_shap_values_for_class(class_idx)
        mean_shap = np.abs(shap_vals).mean(axis=0)
        
        # Create DataFrame for plotting
        importance_df = pd.DataFrame({
            'Feature': self.feature_names,
            'Mean |SHAP|': mean_shap
        }).sort_values('Mean |SHAP|', ascending=True)
        
        # Plot
        fig, ax = plt.subplots(figsize=(10, 8))
        colors = plt.cm.RdYlBu_r(np.linspace(0.2, 0.8, len(importance_df)))
        
        bars = ax.barh(importance_df['Feature'], importance_df['Mean |SHAP|'], color=colors)
        
        ax.set_xlabel('Mean |SHAP Value|', fontsize=12)
        ax.set_ylabel('Feature', fontsize=12)
        ax.set_title(f'Feature Importance (SHAP) - {self.class_names[class_idx]}', 
                     fontsize=14, fontweight='bold')
        
        # Add value labels
        for bar, val in zip(bars, importance_df['Mean |SHAP|']):
            ax.text(val + 0.001, bar.get_y() + bar.get_height()/2, 
                   f'{val:.4f}', va='center', fontsize=9)
        
        plt.tight_layout()
        plt.show()
        
        # Display ranking table
        print("\n   Feature Importance Ranking:")
        print("-" * 40)
        for rank, (_, row) in enumerate(importance_df.iloc[::-1].iterrows(), 1):
            print(f"   {rank}. {row['Feature']:<15} {row['Mean |SHAP|']:.4f}")
        
        print("\n[OK] SHAP bar plot generated")
    
    def plot_shap_force(self, sample_idx: int = 0, class_idx: int = None) -> None:
        """
        Generate SHAP force plot for individual prediction explanation.
        
        Args:
            sample_idx (int): Index of sample to explain (default: 0)
            class_idx (int, optional): Class index. If None, uses predicted class.
        """
        if self.shap_values is None:
            raise ValueError("SHAP values not calculated. Call calculate_shap_values() first.")
        
        print("\n" + "="*60)
        print(f"SHAP FORCE PLOT - Sample {sample_idx}")
        print("="*60)
        
        # Get predicted class if not specified
        if class_idx is None:
            pred_proba = self.model.predict_proba(self.X_sample[sample_idx:sample_idx+1])
            class_idx = np.argmax(pred_proba)
        
        print(f"\n   Explaining prediction for class: {self.class_names[class_idx]}")
        
        # Initialize JavaScript for force plot
        shap.initjs()
        
        # Create force plot
        force_plot = shap.force_plot(
            self.shap_explainer.expected_value[class_idx],
            self._get_shap_values_for_class(class_idx)[sample_idx],
            self.X_sample[sample_idx],
            feature_names=self.feature_names,
            matplotlib=True,
            show=False
        )
        
        plt.title(f'SHAP Force Plot - {self.class_names[class_idx]}', fontsize=12, fontweight='bold')
        plt.tight_layout()
        plt.show()
        
        print("\n[OK] SHAP force plot generated")
    
    def plot_shap_waterfall(self, sample_idx: int = 0, class_idx: int = None) -> None:
        """
        Generate SHAP waterfall plot showing cumulative feature contributions.
        
        Args:
            sample_idx (int): Index of sample to explain (default: 0)
            class_idx (int, optional): Class index. If None, uses predicted class.
        """
        if self.shap_values is None:
            raise ValueError("SHAP values not calculated. Call calculate_shap_values() first.")
        
        print("\n" + "="*60)
        print(f"SHAP WATERFALL PLOT - Sample {sample_idx}")
        print("="*60)
        
        # Get predicted class if not specified
        if class_idx is None:
            pred_proba = self.model.predict_proba(self.X_sample[sample_idx:sample_idx+1])
            class_idx = np.argmax(pred_proba)
        
        print(f"\n   Explaining prediction for class: {self.class_names[class_idx]}")
        
        # Create Explanation object for waterfall plot
        explanation = shap.Explanation(
            values=self._get_shap_values_for_class(class_idx)[sample_idx],
            base_values=self.shap_explainer.expected_value[class_idx],
            data=self.X_sample[sample_idx],
            feature_names=self.feature_names
        )
        
        plt.figure(figsize=(12, 8))
        shap.waterfall_plot(explanation, show=False)
        plt.title(f'SHAP Waterfall - {self.class_names[class_idx]}', fontsize=14, fontweight='bold')
        plt.tight_layout()
        plt.show()
        
        print("\n[OK] SHAP waterfall plot generated")
    
    def plot_shap_dependence(self, feature: str, interaction_feature: str = None, 
                             class_idx: int = 0) -> None:
        """
        Generate SHAP dependence plot for feature interactions.
        
        Args:
            feature (str): Primary feature to analyze
            interaction_feature (str, optional): Feature for interaction coloring
            class_idx (int): Class index (default: 0)
        """
        if self.shap_values is None:
            raise ValueError("SHAP values not calculated. Call calculate_shap_values() first.")
        
        print("\n" + "="*60)
        print(f"SHAP DEPENDENCE PLOT - {feature}")
        print("="*60)
        
        feature_idx = self.feature_names.index(feature)
        
        plt.figure(figsize=(10, 6))
        shap.dependence_plot(
            feature_idx,
            self._get_shap_values_for_class(class_idx),
            self.X_sample,
            feature_names=self.feature_names,
            interaction_index=interaction_feature,
            show=False
        )
        plt.title(f'SHAP Dependence - {feature} ({self.class_names[class_idx]})', 
                  fontsize=14, fontweight='bold')
        plt.tight_layout()
        plt.show()
        
        print("\n[OK] SHAP dependence plot generated")


