# ============================================================
# DataLoader Component
# ============================================================
# Purpose: Load and validate the engine sensor dataset
# Requirements: 1.1, 1.2, 1.3, 1.4, 1.5, 1.6
# ============================================================

class DataLoader:
    """
    DataLoader class for loading and validating the VEHMS engine sensor dataset.
    
    This class provides methods to:
    - Load CSV files into pandas DataFrames
    - Validate that all required columns exist
    - Verify data types for numeric and categorical columns
    - Display dataset summary statistics
    
    Attributes:
        REQUIRED_COLUMNS (list): List of all 10 required column names
        VALID_DECISIONS (list): List of valid Decision category values
    """
    
    # Class constants defining required columns and valid decision values
    REQUIRED_COLUMNS = [
        'Crankshaft', 'Overheating', 'Lubricant', 'Misfires', 
        'Piston', 'Starter', 'Decision', 'Temperature', 
        'Humidity', 'Altitude'
    ]
    
    VALID_DECISIONS = ['Good', 'Minor', 'Moderate', 'Critical']
    
    def __init__(self):
        """
        Initialize the DataLoader instance.
        
        Attributes:
            df (pd.DataFrame): Stores the loaded dataset
            validation_errors (list): Stores any validation errors encountered
        """
        self.df = None
        self.validation_errors = []
    
    def load_dataset(self, filepath: str) -> pd.DataFrame:
        """
        Load a CSV file into a pandas DataFrame.
        
        Args:
            filepath (str): Path to the CSV file to load
            
        Returns:
            pd.DataFrame: The loaded dataset
            
        Raises:
            FileNotFoundError: If the specified file does not exist
            ValueError: If the file cannot be parsed as CSV
        """
        try:
            self.df = pd.read_csv(filepath)
            print(f"[OK] Dataset loaded successfully from: {filepath}")
            print(f"  Shape: {self.df.shape[0]} rows x {self.df.shape[1]} columns")
            return self.df
        except FileNotFoundError:
            raise FileNotFoundError(f"Dataset file not found: {filepath}")
        except Exception as e:
            raise ValueError(f"Error loading dataset: {str(e)}")
    
    def validate_columns(self, df: pd.DataFrame = None) -> bool:
        """
        Validate that all required columns exist in the dataset.
        
        Args:
            df (pd.DataFrame, optional): DataFrame to validate. 
                                         Uses self.df if not provided.
            
        Returns:
            bool: True if all required columns exist, False otherwise
            
        Raises:
            ValueError: If required columns are missing
        """
        if df is None:
            df = self.df
        
        if df is None:
            raise ValueError("No dataset loaded. Call load_dataset() first.")
        
        # Check for missing columns
        existing_columns = set(df.columns)
        required_columns = set(self.REQUIRED_COLUMNS)
        missing_columns = required_columns - existing_columns
        
        if missing_columns:
            error_msg = f"Missing required columns: {sorted(missing_columns)}"
            self.validation_errors.append(error_msg)
            raise ValueError(error_msg)
        
        print(f"[OK] All {len(self.REQUIRED_COLUMNS)} required columns validated:")
        print(f"  Sensor Features: Crankshaft, Overheating, Lubricant, Misfires, Piston, Starter")
        print(f"  Environmental Features: Temperature, Humidity, Altitude")
        print(f"  Target Variable: Decision")
        return True
    
    def validate_data_types(self, df: pd.DataFrame = None) -> bool:
        """
        Validate data types for numeric and categorical columns.
        
        Verifies that:
        - All numeric columns (except Decision) contain valid float values
        - The Decision column contains only valid categories
        
        Args:
            df (pd.DataFrame, optional): DataFrame to validate.
                                         Uses self.df if not provided.
            
        Returns:
            bool: True if all data types are valid, False otherwise
            
        Raises:
            ValueError: If data type validation fails
        """
        if df is None:
            df = self.df
        
        if df is None:
            raise ValueError("No dataset loaded. Call load_dataset() first.")
        
        # Define numeric columns (all except Decision)
        numeric_columns = [col for col in self.REQUIRED_COLUMNS if col != 'Decision']
        
        # Validate numeric columns
        print("\n[OK] Validating numeric columns...")
        invalid_numeric = []
        for col in numeric_columns:
            if col in df.columns:
                # Check if column can be converted to numeric
                if not pd.api.types.is_numeric_dtype(df[col]):
                    # Try to convert and check for failures
                    converted = pd.to_numeric(df[col], errors='coerce')
                    if converted.isna().sum() > df[col].isna().sum():
                        invalid_numeric.append(col)
        
        if invalid_numeric:
            error_msg = f"Invalid numeric values in columns: {invalid_numeric}"
            self.validation_errors.append(error_msg)
            raise ValueError(error_msg)
        
        print(f"  All {len(numeric_columns)} numeric columns contain valid float values")
        
        # Validate Decision column categorical values
        print("\n[OK] Validating Decision column categories...")
        if 'Decision' in df.columns:
            unique_decisions = set(df['Decision'].dropna().unique())
            valid_decisions = set(self.VALID_DECISIONS)
            invalid_decisions = unique_decisions - valid_decisions
            
            if invalid_decisions:
                error_msg = f"Invalid Decision values found: {sorted(invalid_decisions)}. Valid values are: {self.VALID_DECISIONS}"
                self.validation_errors.append(error_msg)
                raise ValueError(error_msg)
            
            print(f"  Valid categories found: {sorted(unique_decisions)}")
            
            # Display category distribution
            print("\n  Category Distribution:")
            for category in self.VALID_DECISIONS:
                count = (df['Decision'] == category).sum()
                percentage = (count / len(df)) * 100
                print(f"    {category}: {count} samples ({percentage:.1f}%)")
        
        return True
    
    def display_summary(self, df: pd.DataFrame = None) -> None:
        """
        Display comprehensive dataset summary including shape, types, and statistics.
        
        Args:
            df (pd.DataFrame, optional): DataFrame to summarize.
                                         Uses self.df if not provided.
        """
        if df is None:
            df = self.df
        
        if df is None:
            raise ValueError("No dataset loaded. Call load_dataset() first.")
        
        print("\n" + "="*60)
        print("DATASET SUMMARY")
        print("="*60)
        
        # Dataset shape
        print(f"\n[STATS] Dataset Shape:")
        print(f"   Rows (samples): {df.shape[0]:,}")
        print(f"   Columns (features): {df.shape[1]}")
        
        # Column types
        print(f"\n[LIST] Column Data Types:")
        print("-" * 40)
        for col in df.columns:
            dtype = df[col].dtype
            print(f"   {col:<15} : {dtype}")
        
        # Basic statistics for numeric columns
        print(f"\n[CHART] Numeric Column Statistics:")
        print("-" * 60)
        numeric_cols = df.select_dtypes(include=[np.number]).columns
        stats_df = df[numeric_cols].describe().T
        stats_df = stats_df[['count', 'mean', 'std', 'min', '25%', '50%', '75%', 'max']]
        print(stats_df.to_string())
        
        # Missing values summary
        print(f"\n[SEARCH] Missing Values:")
        print("-" * 40)
        missing = df.isnull().sum()
        if missing.sum() == 0:
            print("   No missing values detected")
        else:
            for col in df.columns:
                if missing[col] > 0:
                    print(f"   {col}: {missing[col]} missing values")
        
        # First few rows preview
        print(f"\n[VIEW] First 5 Rows Preview:")
        print("-" * 60)
        print(df.head().to_string())
        
        print("\n" + "="*60)
        print("END OF SUMMARY")
        print("="*60)


